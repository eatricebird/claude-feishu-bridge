# 飞书配置
feishu:
  # 飞书应用 ID（从飞书开放平台获取）
  app_id: "your_app_id_here"

  # 飞书应用密钥（从飞书开放平台获取）
  app_secret: "your_app_secret_here"

  # 接收通知的用户 ID（飞书用户的 open_id 或 user_id）
  user_id: "your_user_id_here"

  # 飞书 Encrypt Key（用于验证 webhook 签名，可选）
  encrypt_key: "your_encrypt_key_here"

# Webhook 服务器配置
webhook:
  # 监听端口
  port: 8080

  # 监听地址
  host: "0.0.0.0"

# 存储配置
storage:
  # 权限请求数据存储路径
  path: "./data/permissions.json"

# 权限请求配置
permissions:
  # 等待用户响应的超时时间（秒）
  timeout: 300

  # 轮询间隔（秒）
  poll_interval: 2
